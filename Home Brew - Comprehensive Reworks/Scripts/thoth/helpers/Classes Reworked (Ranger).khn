local __util = require 'larian.util'

function IsFrontierBallistics()
    return (
        SpellId('Projectile_Ranger_ArrowOfAberrationSlaying')
        | SpellId('Projectile_Ranger_ArrowOfAcid')
        | SpellId('Projectile_Ranger_ArrowOfBeastSlaying')
        | SpellId('Projectile_Ranger_ArrowOfConstructSlaying')
        | SpellId('Projectile_Ranger_ArrowOfDarkness')
        | SpellId('Projectile_Ranger_ArrowOfDispelling')
        | SpellId('Projectile_Ranger_ArrowOfElementalSlaying')
        | SpellId('Projectile_Ranger_ArrowOfFiendSlaying')
        | SpellId('Projectile_Ranger_ArrowOfFire')
        | SpellId('Projectile_Ranger_ArrowOfHumanoidSlaying')
        | SpellId('Projectile_Ranger_ArrowOfIce')
        | SpellId('Projectile_Ranger_ArrowOfWraithsEmbrace')
        | SpellId('Projectile_Ranger_ArrowOfLightning')
        | SpellId('Projectile_Ranger_ArrowOfRicochet')
        | SpellId('Projectile_Ranger_ArrowOfMonstrositySlaying')
        | SpellId('Projectile_Ranger_ArrowOfPiercing')
        | SpellId('Projectile_Ranger_ArrowOfDetonation')
        | SpellId('Projectile_Ranger_ArrowOfTeleportation')
        | SpellId('Projectile_Ranger_ArrowOfUndeadSlaying')
    )
    & ~NumberOfTargetsGreaterThan(1)
    & ~AreaRadiusGreaterThan(0)
end